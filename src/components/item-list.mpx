<!--
  ItemList 组件
  用途：医疗服务项目列表组件，用于展示项目列表和快速购买
  功能：
    - 以列表形式展示多个服务项目
    - 显示项目封面图、名称、价格信息
    - 提供快捷购买按钮，方便用户快速下单
    - 支持价格对比展示（原价vs折扣价）
    - 采用横向卡片布局，信息展示清晰
    - 点击项目或购买按钮都可跳转到详情页
  使用场景：项目列表页、推荐项目、搜索结果等
-->
<template>
  <view class="flex flex-col gap-[16rpx]">
    <view wx:for="{{ localItems }}" wx:key="id" bindtap="goItemDetail" data-id="{{ item.id }}"
      class="flex items-center gap-[20rpx]">
      <view class="w-[166rpx] h-[126rpx] of-hidden rounded-[16rpx] flex items-center justify-center">
        <t-image webp="{{ true }}" src="{{ item.cover_image }}" width="166rpx" height="126rpx" t-class="of-hidden" mode="aspectFill" />
      </view>

      <view class="flex flex-col flex-1 gap-[22rpx] min-w-0">
        <view class="text-[28rpx] color-[#090E0B] font-bold truncate">{{
          item.name }}</view>
        <view class="flex items-center justify-between">
          <view class="flex items-center gap-[10rpx]">
            <view wx:if="{{ item.lto }}"
              class="color-[#F42020] font-bold text-[20rpx] px-[8rpx] border border-solid border-[#F42020] rounded-[8rpx]">
              秒杀</view>
            <view class="text-[28rpx] font-bold color-[#F42020]">￥{{ item.discount_price }}</view>
            <view class="text-[24rpx] color-[#1D2129] font-400 line-through mx-[6rpx]">￥{{ item.original_price }}
            </view>
          </view>
          <t-button theme="primary" size="extra-small" t-class="buy" bindtap="goItemDetail"
            data-id="{{ item.id }}">购买</t-button>
        </view>
      </view>
    </view>
  </view>
</template>

<script lang="ts">
import { type Item } from '@/store/item';
import mpx, { createComponent } from '@mpxjs/core';
import dayjs from 'dayjs';

createComponent({
  props: {
    items: {
      type: Array,
      value: [] as Item[],
    },
  },
  computed: {
    localItems() {
      return this.items.map((item: Item) => {
        const { marketing_activities } = item;

        const lto = marketing_activities?.seckill_activity
          && marketing_activities.seckill_activity.stock
          && marketing_activities.seckill_activity.seckill_price
          && dayjs().isBefore(dayjs(marketing_activities.seckill_activity.end_time));

        return {
          ...item,
          lto,
          discount_price: lto ? marketing_activities.seckill_activity!.seckill_price : item.discount_price,
        };
      });
    },
  },
  methods: {
    goItemDetail(e: WechatMiniprogram.CustomEvent) {
      const { id } = e.currentTarget.dataset;
      mpx.redirectTo({
        url: `/pages/item/detail?id=${id}`
      });
    },
  },
});
</script>

<style lang="less">
.buy {
  --td-button-primary-color: white;
  --td-button-primary-bg-color: #FF7913;
  --td-button-primary-border-color: #FF7913;
  --td-button-primary-active-bg-color: #FF7913;
  --td-button-primary-active-border-color: #FF7913;
  --td-button-extra-small-font-size: 24rpx;
  margin: 0;
  width: 108rpx;
  height: 44rpx;
}
</style>

<script type="application/json">
{
  "component": true,
  "usingComponents": {
    "t-button": "tdesign-miniprogram/miniprogram_dist/button/button",
    "t-image": "tdesign-miniprogram/miniprogram_dist/image/image",
  }
}
</script>
