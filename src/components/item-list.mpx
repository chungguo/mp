<template>
  <view class="flex flex-col gap-[16rpx]">
    <view wx:for="{{ items }}" wx:key="id" bindtap="goItemDetail" data-id="{{ item.id }}"
      class="flex items-center gap-[20rpx]">
      <view class="w-[166rpx] h-[126rpx] of-hidden rounded-[16rpx] flex items-center justify-center">
        <t-image src="{{ item.cover_image }}" t-class="w-[166rpx] h-[126rpx] of-hidden" mode="widthFix" />
      </view>

      <view class="flex flex-col flex-1 gap-[22rpx] min-w-0">
        <view class="text-[28rpx] color-[#090E0B] font-bold text-ellipsis overflow-hidden whitespace-nowrap">{{
          item.name }}</view>
        <view class="flex items-center justify-between">
          <view class="flex items-center gap-[10rpx]">
            <view class="text-[28rpx] font-bold color-[#F42020]">￥{{ item.original_price }}</view>
            <view class="text-[24rpx] color-[#1D2129] font-400 line-through mx-[6rpx]">￥{{ item.discount_price }}
            </view>
          </view>
          <t-button theme="primary" size="extra-small" t-class="buy" bindtap="goItemDetail"
            data-id="{{ item.id }}">购买</t-button>
        </view>
      </view>
    </view>
  </view>
</template>

<script lang="ts">
import { type Item } from '@/store/item';
import mpx, { createComponent } from '@mpxjs/core';

createComponent({
  props: {
    items: {
      type: Array,
      value: [] as Item[],
    },
  },
  methods: {
    goItemDetail(e: WechatMiniprogram.CustomEvent) {
      const { id } = e.currentTarget.dataset;
      mpx.navigateTo({
        url: `/pages/item/detail?id=${id}`
      });
    },
  },
});
</script>

<style lang="less">
.buy {
  --td-button-primary-color: white;
  --td-button-primary-bg-color: #FF7913;
  --td-button-primary-border-color: #FF7913;
  --td-button-primary-active-bg-color: #FF7913;
  --td-button-primary-active-border-color: #FF7913;
  --td-button-extra-small-font-size: 24rpx;
  margin: 0;
}
</style>

<script type="application/json">
{
  "component": true,
  "usingComponents": {
    "t-button": "tdesign-miniprogram/miniprogram_dist/button/button",
    "t-image": "tdesign-miniprogram/miniprogram_dist/image/image",
  }
}
</script>
