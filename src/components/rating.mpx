<template>
  <view class="flex items-center gap-[16rpx]">
    <t-rate class="rate" value="{{ value }}" color="#FFC14A" size="30rpx" gap="6rpx" disabled allow-half />
    <view class="text-[22rpx] color-[#090E0B]" wx:if="{{ value }}">{{ showText }}</view>
  </view>
</template>

<script lang="ts">
import { createComponent } from '@mpxjs/core';

createComponent({
  props: {
    value: {
      type: Number,
      value: 0,
    },
  },
  data: {
    icon: [
      'data:image/png;base64,',
      'data:image/png;base64,'
    ],
  },
  computed: {
    showText() {
      return this.value.toFixed(1);
    }
  },
});
</script>

<style lang="less">
.rate {
  --td-rate-text-font-size: 22rpx;
}
</style>

<script type="application/json">
{
  "component": true,
  "usingComponents": {
    "t-rate": "tdesign-miniprogram/miniprogram_dist/rate/rate",
  }
}
</script>
