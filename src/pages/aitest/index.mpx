<template>
  <t-navbar left-arrow bind:go-back="goBack" title="AI 牙齿健康测"></t-navbar>

  <view wx:if="{{ uploaded }}" class="absolute top-0 left-0 right-0 z-1">
    <image src="https://yjb-1376872341.cos.ap-shanghai.myqcloud.com/public/aitest/banner.png" mode="widthFix" />

    <view class="px-[26rpx]">
      <view class="text-[36rpx] color-[#1D2129] mt-[10rpx] mb-[52rpx] text-center font-bold">
        领专属 <text class="color-[#4287FF] text-[66rpx] mx-[20rpx]">0</text> 元福利
      </view>
