<template>
  <view class="relative">

    <t-navbar title="健牙宝" />

    <view class="hero-cards p-[32rpx]">
      <view class="flex gap-[22rpx] items-center">
        <view class="relative w-[302rpx] h-[306rpx] rounded-[26rpx] of-hidden" bindtap="navigateToAiTest">
          <t-image src="https://yjb-1376872341.cos.ap-shanghai.myqcloud.com/public/index/aitest.png" width="302rpx"
            height="306rpx" shape="rounded" />
          <view class="absolute top-0 left-0 flex flex-col color-white pl-[30rpx] pt-[36rpx] gap-[6rpx]">
            <text class="text-[30rpx] font-800">AI·牙卫士</text>
            <text class="text-[24rpx]">测测你的牙齿状况</text>
          </view>
        </view>
        <view class="flex flex-col gap-[22rpx]">
          <view class="box-border bg-white p-[36rpx] rounded-[22rpx] flex gap-[24rpx] items-center"
            bindtap="navigateToPackageInsurance">
            <t-image width="80rpx" height="80rpx"
              src="https://yjb-1376872341.cos.ap-shanghai.myqcloud.com/public/index/%E7%88%B1%E7%89%99%E6%97%A0%E5%BF%A7%E5%8C%85.png" />
            <view>
              <view class="text-[30rpx] font-bold color-[#1D2129]">爱牙无忧包</view>
              <view class="text-[24rpx] color-[#86909C]">基础项目安心全包</view>
            </view>
          </view>
          <view class="flex gap-[22rpx]">
            <view bindtap="navigateToConsultationForm"
              class="box-border rounded-[22rpx] flex-1 p-[12rpx] bg-white flex flex-col justify-center items-center gap-[6rpx]">
              <view class="color-[#1D2129] text-[28rpx] font-bold">专属客服</view>
              <t-image width="80rpx" height="80rpx"
                src="https://yjb-1376872341.cos.ap-shanghai.myqcloud.com/public/index/%E4%B8%93%E5%B1%9E%E5%AE%A2%E6%9C%8D.png" />
            </view>
            <view bindtap="navigateToActivityReferral"
              class="box-border rounded-[22rpx] flex-1 p-[12rpx] bg-white flex flex-col justify-center items-center gap-[6rpx]">
              <view class="color-[#1D2129] text-[28rpx] font-bold">分享领好礼</view>
              <t-image width="80rpx" height="80rpx"
                src="https://yjb-1376872341.cos.ap-shanghai.myqcloud.com/public/index/%E5%88%86%E4%BA%AB%E9%A2%86%E5%A5%BD%E7%A4%BC.png" />
            </view>
          </view>
        </view>
      </view>
    </view>

    <t-grid column="{{ 0 }}" theme="card">
      <t-grid-item wx:for="{{ grids }}" wx:key="text" text={{item.name}} url="{{ item.path }}" t-class="!w-[140rpx]">
        <t-image src="{{ item.image }}" t-class="w-[60rpx] h-[60rpx]" />
      </t-grid-item>
    </t-grid>

    <view class="p-[32rpx] pt-0">
      <!-- 特惠洗牙券广告 -->
      <t-swiper wx:if="{{ banner.length !== 0 }}" list="{{ banner }}" height="184rpx" bind:click="onSwiperClick"
        navigation="{{ { type: 'dots-bar' } }}" t-class="mt-[26rpx]" />

      <!-- 主内容区域 -->
      <t-tabs value="{{ activeTab }}" bind:change="onTabsChange" theme="line" t-class="tabs mt-[26rpx]">
        <t-tab-panel label="优势项目" value="item">
          <view class="flex flex-wrap gap-[22rpx] mt-[26rpx]">
            <block wx:for="{{ items }}" wx:key="id">
              <item item="{{ item }}" />
            </block>
          </view>
        </t-tab-panel>

        <t-tab-panel label="甄选机构" value="hospital">
          <view class="flex flex-col gap-[16rpx] mt-[26rpx]">
            <view class="w-full box-border bg-white rounded-[22rpx] px-[26rpx] py-[36rpx]" wx:for="{{ hospitals }}"
              wx:if="{{ hospital.items.length !== 0 }}" wx:key="id" wx:for-item="hospital"
              bindtap="navigateToHospitalDetail" data-id="{{ hospital.id }}">
              <view class="flex items-center gap-[22rpx]">
                <view class="w-[140rpx] h-[140rpx] of-hidden rounded-[22rpx] flex items-center justify-center">
                  <t-image src="{{ hospital.images && hospital.images[0] }}" width="140rpx" height="140rpx" />
                </view>
                <view class="flex flex-col justify-center flex-1 gap-[12rpx]">
                  <text
                    class="text-[28rpx] color-[#090E0B] font-bold overflow-hidden whitespace-nowrap text-ellipsis">{{
                      hospital.name }}</text>
                  <rate value="{{ Math.ceil(hospital.rating) }}" />
                  <view class="flex items-center gap-[36rpx] of-hidden flex-nowrap">
                    <view wx:for="{{ hospital.tags.split(',') }}" wx:for-item="tag" wx:key="*this"
                      class="border border-[#4A8DFF] flex-shrink-0 text-[18rpx] color-[#4A8DFF] px-[12rpx] py-[2rpx] rounded-[10rpx]">
                      {{ tag }}</view>
                  </view>
                </view>
              </view>
              <t-divider />
              <view class="flex flex-col gap-[22rpx]">
                <view wx:for="{{ hospital.items }}" wx:key="id" class="flex items-center gap-[26rpx]">
                  <view class="color-[#F42020] font-bold text-[28rpx] min-w-[100rpx]">￥{{ item.discount_price }}</view>
                  <view wx:if="{{ discountText }}"
                    class="color-[#F42020] font-bold text-[20rpx] px-[8rpx] border border-solid border-[#F42020] rounded-[8rpx]">
                    {{ item.discountText }}</view>
                  <view class="text-ellipsis overflow-hidden whitespace-nowrap color-[#090E0B] text-[22rpx]">{{
                    item.name }}</view>
                </view>
              </view>
            </view>
          </view>
        </t-tab-panel>

        <t-tab-panel label="口碑医生" value="doctor">
          <view class="flex flex-col gap-[16rpx] mt-[26rpx]">
            <view wx:for="{{ doctors }}" wx:key="id"
              class="flex items-center bg-white box-border px-[26rpx] py-[36rpx] gap-[22rpx] rounded-[22rpx]"
              bindtap="navigateToDoctorDetail" data-id="{{ item.id }}">
              <view class="relative rounded-[16rpx]">
                <t-image t-class="rounded-[16rpx] of-hidden w-[194rpx] h-[194rpx]" src="{{ item.avatar }}" />
                <view
                  class="bg-[#4A8DFF] absolute z-2 bottom-0 left-0 right-0 color-white text-center text-ellipsis  of-hidden whitespace-nowrap rounded-b-[16rpx] text-[22rpx] py-[5rpx]">
                  {{ item.title }}
                </view>
              </view>
              <view class="flex-1 flex flex-col gap-[14rpx] min-w-0">
                <view class="flex justify-between items-center">
                  <view class="color-[#090E0B] text-[36rpx] font-bold">{{ item.name }}</view>
                  <view wx:if="{{ item.experienceYear }}" class="color-[#51555E] text-[24rpx]">从业{{ item.experienceYear
                  }}年</view>
                </view>
                <view class="text-[24rpx] color-[#51555E] flex flex-col gap-[10rpx]">
                  <view class="text-ellipsis of-hidden whitespace-nowrap">{{ item.hospitals }}</view>
                  <view>{{ item.department }}</view>
                </view>
              </view>
            </view>
          </view>
        </t-tab-panel>
      </t-tabs>
    </view>
  </view>
</template>
<script lang="ts">
import mpx, { createPage } from '@mpxjs/core';
import { mapActions, mapState } from '@mpxjs/pinia';
import { useUserStore } from '@/store/user';
import { Doctor, useDoctorStore } from '@/store/doctor';
import { type Hospital, useHospitalStore } from '@/store/hospital';
import { type Item, useItemStore } from '@/store/item';
import { type Category, useCategoryStore } from '@/store/category';
import { type ReturningUserActivity, useReferralStore } from '@/subpackages/activity/store';
import dayjs from 'dayjs';

createPage({
  data: {
    loadingHospital: false,
    loadingDoctor: false,

    grids: [] as (Category & { path: string })[],

    banner: [] as string[],

    activeTab: '',

    hospitals: [] as (Hospital & {
      items: (Item & { discountText?: string })[]
    })[],

    items: [] as (Item & {
      hospitals: string[],
      discountText?: string,
      original_price_text: string;
      discount_price_text: string;
    })[],

    icon: [
      'data:image/png;base64,',
      'data:image/png;base64,'
    ],
    texts: ['1分', '2分', '3分', '4分', '5分'],
    returningUserActivities: [] as ReturningUserActivity[],
  },
  ...mapState(useUserStore, ['newUser']),
  ...mapActions(useItemStore, ['fetchItems']),
  ...mapActions(useDoctorStore, ['fetchDoctors']),
  ...mapActions(useHospitalStore, ['fetchHospitals']),
  ...mapActions(useCategoryStore, ['fetchCategories']),
  pageLifetimes: {
    show() {
      if (typeof this.getTabBar === 'function') {
        this.getTabBar().setData({
          tab: 'index',
        })
      }
    },
  },
  computed: {
    newUserVal() {
      return this.newUser();
    }
  },

  watch: {
    async activeTab(newValue) {
      if (newValue === 'item') {
        this.queryItems();
      }

      if (newValue === 'hospital') {
        this.queryHospitals();
      }

      if (newValue === 'doctor') {
        this.queryDoctors();
      }
    },
    newUserVal(v) {
      if (v === true) {
        this.setData({
          banner: ['https://yjb-1376872341.cos.ap-shanghai.myqcloud.com/public/lowcode-2385151.png']
        });
      }
      if (v === false) {
        this.queryReturningUserActivity();
      }
    },
  },
  onLoad() {
    this.activeTab = 'item';
    this.fullfillCategory();
  },

  /**
   * 切换标签页
   */
  onTabsChange(e: WechatMiniprogram.CustomEvent) {
    this.activeTab = e.detail.value;
  },

  async fullfillCategory() {
    try {
      const data = await this.fetchCategories();

      this.setData({
        grids: data.filter((item: Category) => item.level === 1).map((item: Category) => ({
          ...item,
          path: `/pages/item/list?category_id=${item.id}`,
        }))
      });
    } catch (e) {
      console.error(e)
    }
  },
  async onSwiperClick(e: WechatMiniprogram.CustomEvent) {
    if (this.newUserVal) {
      mpx.navigateTo({
        url: '/pages/coupon/list',
      });
      return;
    }

    const { index } = e.detail;

    const activity = this.returningUserActivities[index];

    if (!activity) {
      mpx.showToast({
        title: '活动不存在',
        icon: 'error',
      })
      return;
    }

    mpx.navigateTo({
      url: `/subpackages/activity/referral?activity_id=${activity.id}`,
    });
  },

  async queryReturningUserActivity() {
    const store = useReferralStore();
    const res = await store.avaliable();
    const activities = res.filter(item => item.status === 2 && item.can_participate);

    this.setData({
      returningUserActivities: activities,
      banner: activities.map(item => item.banner_image).filter(Boolean),
    });
  },

  async queryHospitals() {
    try {
      mpx.showLoading({
        title: '加载中...',
      });

      const hospitals = await this.fetchHospitals();
      const res = await this.fetchItems({
        hospital_ids: hospitals.map((h: Hospital) => h.id).join(','),
      });

      this.setData({
        hospitals: hospitals.map((h: Hospital) => ({
          ...h,
          items: res.items.filter((i: Item) => i.hospital_ids.includes(h.id)).map((i: Item) => ({
            ...i,
            discountText: this.getDiscount(i),
          }))
        })),
      });
    } finally {
      mpx.hideLoading();
    }
  },

  async queryDoctors() {
    try {
      mpx.showLoading({
        title: '加载中...',
      });
      const res = await this.fetchDoctors();
      const hospitals = await this.fetchHospitals();
      this.setData({
        doctors: res.doctors.map((d: Doctor) => ({
          ...d,
          experienceYear: d.practice_year && Math.max(Number(dayjs().format('YYYY')) - d.practice_year, 1),
          hospitals: d.hospital_ids.map((id: number) => hospitals.find((h: Hospital) => h.id === id)).map(h => h.name).join(','),
        })),
      });
    } finally {
      mpx.hideLoading();
    }
  },

  async queryItems() {
    try {
      mpx.showLoading({
        title: '加载中...',
      });

      const res = await this.fetchItems();
      const hospitals = await this.fetchHospitals();

      this.setData({
        items: res.items.map((item: Item) => ({
          ...item,
          hospitals: item.hospital_ids.map((id: number) => hospitals.find((h: Hospital) => h.id === id)).map(h => h.name).join(','),
          discountText: this.getDiscount(item),
        })),
      })
    } finally {
      mpx.hideLoading();
    }
  },

  getDiscount(item: Item) {
    if (!item) {
      return;
    }

    const { original_price, discount_price } = item;
    const discount = original_price - discount_price;

    if (!discount) {
      return;
    }

    const num = ((discount_price / original_price) * 10).toFixed(1);

    if (Number(num) === 0) {
      return;
    }

    return `${num}折`;
  },
  navigateToItemDetail(e: WechatMiniprogram.CustomEvent) {
    const { id } = e.currentTarget.dataset;
    mpx.navigateTo({
      url: `/pages/item/detail?id=${id}`
    });
  },

  navigateToHospitalDetail(e: WechatMiniprogram.CustomEvent) {
    const { id } = e.currentTarget.dataset;
    mpx.navigateTo({
      url: `/pages/hospital/detail?id=${id}`
    });
  },

  navigateToDoctorDetail(e: WechatMiniprogram.CustomEvent) {
    const { id } = e.currentTarget.dataset;
    mpx.navigateTo({
      url: `/pages/doctor/detail?id=${id}`
    });
  },

  navigateToAiTest() {
    mpx.switchTab({
      url: '/pages/aitest/index',
    });
  },
  navigateToConsultationForm() {
    mpx.navigateTo({
      url: '/pages/consultation/form',
    });
  },
  navigateToPackageInsurance() {
    mpx.navigateTo({
      url: '/pages/package/insurance',
    });
  },
  navigateToActivityReferral() {
    const activity = this.returningUserActivities[0];
    if (!activity) {
      mpx.showToast({
        title: '活动不存在',
        icon: 'error',
      });
      return;
    }

    mpx.navigateTo({
      url: `/subpackages/activity/referral?activity_id=${activity.id}`,
    });
  }
});
</script>

<script type="application/json">
  {
    "navigationBarTitleText": "首页",
    "navigationStyle": "custom",
    "usingComponents": {
      "t-navbar": "tdesign-miniprogram/miniprogram_dist/navbar/navbar",
      "t-tabs": "tdesign-miniprogram/miniprogram_dist/tabs/tabs",
      "t-tab-panel": "tdesign-miniprogram/miniprogram_dist/tab-panel/tab-panel",
      "t-swiper": "tdesign-miniprogram/miniprogram_dist/swiper/swiper",
      "t-swiper-nav": "tdesign-miniprogram/miniprogram_dist/swiper-nav/swiper-nav",
      "t-image": "tdesign-miniprogram/miniprogram_dist/image/image",
      "t-grid": "tdesign-miniprogram/miniprogram_dist/grid/grid",
      "t-grid-item": "tdesign-miniprogram/miniprogram_dist/grid-item/grid-item",
      "t-divider": "tdesign-miniprogram/miniprogram_dist/divider/divider",
      "rate": "@/components/rating",
      "item": "@/components/item",
    }
  }
</script>

<style>
/* 页面基础样式 */
page {
  --td-navbar-color: white;
  --td-grid-item-text-font-size: 24rpx;
  --td-tab-font-size: 32rpx;
  --td-tab-item-height: 69rpx;
  --td-navbar-background: linear-gradient(180deg, #317DFF 0%, #3E85FF 100%);
  background-color: #F1F3F7;
}

.hero-cards {
  background: linear-gradient(180deg, #3E85FF 0%, #F1F3F7 100%);
}
</style>
